---
import Eyebrow from "./Eyebrow.astro";
import SectionHeader from "./SectionHeader.astro";
import FeatureGrid from "./FeatureGrid.astro";
import Faq from "./Faq.astro";
import PaymentCTA from "./PaymentCTA.astro";

// Static imports so Astro reliably hoists EACH tool's <script> only on the page
// where that tool actually renders. (A dynamic <ToolImpl/> breaks Astro's script
// hoisting — the bundle ships but the init never runs.)
import RateCalculator from "/src/tools/rate-calculator.astro";
import SaasMetrics from "/src/tools/saas-metrics.astro";
import MortgagePayoff from "/src/tools/mortgage-payoff.astro";
import QuoteEstimator from "/src/tools/quote-estimator.astro";
import InvoiceGenerator from "/src/tools/invoice-generator.astro";
import MetaTags from "/src/tools/meta-tags.astro";
import UtmBuilder from "/src/tools/utm-builder.astro";
import ResumeBullets from "/src/tools/resume-bullets.astro";
import PolicyGenerator from "/src/tools/policy-generator.astro";
import ColdEmailGenerator from "/src/tools/cold-email-generator.astro";

interface Props { project: any; }
const { project } = Astro.props;
const p = project;
const idTag = String(p.id ?? 0).padStart(3, "0");
const hasPro = (p.pricing?.tiers?.length ?? 0) > 0;
const known = ["rate-calculator","saas-metrics","mortgage-payoff","quote-estimator","invoice-generator","meta-tags","utm-builder","resume-bullets","policy-generator","cold-email-generator"];
const missing = !known.includes(p.tool);
---
<!-- ===================== HERO (compact; tool is the hero) ===================== -->
<section class="relative overflow-hidden border-b border-line">
  <div class="absolute inset-0 grid-lines opacity-[0.5] [mask-image:radial-gradient(70%_60%_at_30%_0%,#000,transparent)]" aria-hidden="true"></div>
  <div class="container-x relative pt-14 pb-10 lg:pt-20 lg:pb-12">
    <div class="max-w-3xl reveal">
      <Eyebrow text={`${idTag} · free tool · runs in your browser`} />
      <h1 class="mt-5 text-display !text-[clamp(2.2rem,1.3rem+3.2vw,3.8rem)]">{p.headline}</h1>
      <p class="lead mt-5 max-w-2xl">{p.subheadline}</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6">
        {(p.proofPoints ?? ["100% client-side — nothing is uploaded", "No signup", "Free forever"]).map((pt: string) => (
          <span class="flex items-center gap-2 text-[0.85rem] text-ink-soft">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {pt}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ===================== THE TOOL ===================== -->
<section id="tool" class="bg-surface-2 border-b border-line">
  <div class="container-x py-10 lg:py-14">
    <div class="card !p-0 overflow-hidden shadow-lg reveal">
      <div class="flex items-center gap-2 px-5 py-3 border-b border-line bg-surface">
        <span class="w-2.5 h-2.5 rounded-full bg-accent/80"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-line-strong"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-line-strong"></span>
        <span class="mono text-[0.7rem] tracking-widest text-muted ml-3 uppercase">{p.name}</span>
        <span class="mono text-[0.66rem] text-muted ml-auto hidden sm:block">LOCAL · PRIVATE</span>
      </div>
      <div class="p-5 lg:p-8">
        {p.tool === "rate-calculator" && (<RateCalculator project={p} />)}
        {p.tool === "saas-metrics" && (<SaasMetrics project={p} />)}
        {p.tool === "mortgage-payoff" && (<MortgagePayoff project={p} />)}
        {p.tool === "quote-estimator" && (<QuoteEstimator project={p} />)}
        {p.tool === "invoice-generator" && (<InvoiceGenerator project={p} />)}
        {p.tool === "meta-tags" && (<MetaTags project={p} />)}
        {p.tool === "utm-builder" && (<UtmBuilder project={p} />)}
        {p.tool === "resume-bullets" && (<ResumeBullets project={p} />)}
        {p.tool === "policy-generator" && (<PolicyGenerator project={p} />)}
        {p.tool === "cold-email-generator" && (<ColdEmailGenerator project={p} />)}
        {missing && (
          <div class="text-center py-16">
            <p class="mono text-[0.75rem] tracking-widest text-muted uppercase mb-2">Tool module “{p.tool}” not found</p>
            <p class="text-ink-soft">Add <code class="mono text-[0.85rem]">src/tools/{p.tool}.astro</code> and map it in ToolTemplate.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<!-- ===================== WHY / FEATURES ===================== -->
{p.features?.length > 0 && (
  <section>
    <div class="container-x py-16 lg:py-20">
      <div class="grid lg:grid-cols-[0.5fr_1fr] gap-8 lg:gap-14 mb-10">
        <SectionHeader num="01" kicker="Why this one" title={p.solution} />
        <p class="lead text-ink-soft reveal self-end">{p.painPoint}</p>
      </div>
      <FeatureGrid features={p.features} />
    </div>
  </section>
)}

<!-- ===================== PRO UPSELL ===================== -->
{hasPro && (
  <section class="container-x py-6">
