---
interface Props { features?: { title: string; body: string }[]; cols?: 2 | 3; class?: string; }
const { features = [], cols = 3, class: cls = "" } = Astro.props;
const grid = cols === 2 ? "sm:grid-cols-2" : "sm:grid-cols-2 lg:grid-cols-3";
---
<ul class:list={["grid gap-4 list-none p-0 m-0", grid, cls]}>
  {features.map((f, i) => (
    <li class="card card--hover reveal" style={`transition-delay:${i * 60}ms`}>
      <span class="mono text-[0.72rem] tracking-widest text-muted">{String(i + 1).padStart(2, "0")}</span>
      <h3 class="mt-3 mb-2 text-[1.12rem]">{f.title}</h3>
      <p class="text-[0.95rem] text-ink-soft m-0">{f.body}</p>
    </li>
  ))}
</ul>
