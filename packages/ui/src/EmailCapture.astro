---
import Button from "./Button.astro";
import { resolveForm, hiddenFields } from "@factory/forms";
interface Props { project: any; title?: string; note?: string; cta?: string; id?: string; }
const { project, title = "Join the waitlist", note = "No spam. One email when it's ready.", cta = "Notify me", id = "waitlist" } = Astro.props;
const f = resolveForm(project);
const hidden = hiddenFields(project);
const data: Record<string, string> = {};
if (f.placeholder) data["data-placeholder"] = "true";
---
<div id={id} class="card reveal" {...data}>
  <h3 class="text-[1.15rem] mb-1">{title}</h3>
  <p class="text-[0.92rem] text-ink-soft mb-4">{note}</p>

  {f.placeholder ? (
    <div class="flex items-center gap-3" data-capture="soon">
      <span class="btn btn--ghost" aria-disabled="true">Coming soon</span>
      <span class="text-[0.8rem] text-muted">Sign-up opens at launch.</span>
    </div>
  ) : f.mode === "post" ? (
    <form action={f.endpoint} method="POST" class="flex flex-col sm:flex-row gap-3" data-capture="post">
      {hidden.map((h) => <input type="hidden" name={h.name} value={h.value} />)}
      <label class="sr-only" for={`${id}-email`}>Email address</label>
      <input id={`${id}-email`} name="email" type="email" required placeholder="you@work.com"
        class="flex-1 px-4 py-3 rounded-[11px] border border-line-strong bg-paper text-ink placeholder:text-muted focus:outline-none focus-visible:outline-accent" />
      <Button type="submit" variant="accent">{cta}</Button>
    </form>
  ) : (
    <div class="flex flex-col sm:flex-row gap-3 items-start" data-capture="redirect">
      <Button href={f.endpoint} variant="accent" external={true} dataAttrs={data}>{cta}</Button>
      <span class="text-[0.8rem] text-muted self-center">Opens a 20-second form.</span>
    </div>
  )}
</div>
