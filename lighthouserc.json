{
  "ci": {
    "collect": {
      "staticDistDir": "./apps/web/dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/projects/index.html",
        "http://localhost/tools/rate-calculator/index.html",
        "http://localhost/services/resume-rewrite/index.html",
        "http://localhost/directories/free-tier-dev/index.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.92 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
