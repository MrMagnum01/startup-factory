# ──────────────────────────────────────────────────────────────────────
# Startup Factory — environment template. Copy to .env (never commit .env).
# Everything is OPTIONAL: the site builds and deploys with zero env vars.
# All values below are placeholders — TODO: replace with your real ones.
# ──────────────────────────────────────────────────────────────────────

# Canonical site URL (set in Vercel → Project → Settings → Environment Variables)
SITE_URL=https://your-domain.vercel.app   # TODO

# ---- Analytics (pick ONE provider, leave the rest unset) ----
# Plausible (paid after trial) — or self-host CE for free
PUBLIC_PLAUSIBLE_DOMAIN=                  # TODO e.g. your-domain.com
PUBLIC_PLAUSIBLE_SRC=                     # optional, default https://plausible.io/js/script.js

# Umami Cloud free tier (https://umami.is) — recommended free option
PUBLIC_UMAMI_ID=                          # TODO website ID from Umami dashboard
PUBLIC_UMAMI_SRC=                         # optional, default https://cloud.umami.is/script.js

# Google Analytics 4 (free)
PUBLIC_GA_ID=                             # TODO e.g. G-XXXXXXXXXX

# ---- Payments & forms ----
# No env needed: payment links (Stripe/Gumroad/Lemon Squeezy) and form links
# (Tally/Formspree) are pasted directly into project configs, replacing the
# TODO_REPLACE_ME placeholders. See docs/LAUNCH-CHECKLIST.md.
